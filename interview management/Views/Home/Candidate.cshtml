@{
    ViewBag.Title = "Candidate Registration";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

<style>
    #tblCandidateList {
        font-size: 12px;
    }

        #tblCandidateList thead th {
            font-size: 12px;
            white-space: nowrap;
            padding: 6px 8px;
        }

        #tblCandidateList tbody td {
            padding: 5px 8px;
            vertical-align: middle;
            white-space: nowrap;
        }

            /* Action column: fixed width, wrap buttons inside */
            #tblCandidateList tbody td:last-child {
                white-space: normal;
                min-width: 140px;
                width: 140px;
            }

        #tblCandidateList .btn-sm {
            font-size: 11px;
            padding: 3px 7px;
        }

    /* ADDED: kill all scrollbars */
    .dataTables_wrapper {
        width: 100%;
        overflow: hidden; /* removes horizontal scrollbar from DataTables wrapper */
    }

    body {
        overflow-x: hidden; /* removes browser-level horizontal scrollbar */
    }
</style>

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>Candidate Registration</h2>
        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#candidateModal">
            <i class="bi bi-person-plus-fill"></i>
            Add Candidate
        </button>
    </div>

    <table id="tblCandidateList"
           class="table table-bordered table-striped w-100">
        <thead class="table-dark">
            <tr>
                <th>Sr. No</th>
                <th>Name</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Gender</th>
                <th>Position</th>
                <th>Qualification</th>
                <th>Experience</th>
                <th>Address</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

</div>

<!-- Candidate Modal -->
<div class="modal fade" id="candidateModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Candidate Registration</h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <div class="row">
                    <input type="hidden" id="inputCandidateId" value="0" />

                    <div class="col-md-6 mb-3">
                        <label>Candidate Name</label>
                        <input type="text" id="inputCandidateName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Email</label>
                        <input type="email" id="inputCNEmail" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Mobile</label>
                        <input type="text" id="inputCNMobNo" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Gender</label>
                        <select id="inputCNGender" class="form-control">
                            <option value="">Select</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Position Applied</label>
                        <input type="text" id="inputCNPositionApplied" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Qualification</label>
                        <input type="text" id="inputCNQualification" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-2">
                        <label>Experience</label>
                        <input type="text" id="inputCNExperience" class="form-control" />
                    </div>

                    <div class="col-md-12 mb-4">
                        <label>Address</label>
                        <textarea id="inputCNAddress" class="form-control" rows="6"></textarea>
                    </div>

                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-success" onclick="CandidateSave()">Save Candidate</button>
            </div>

        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="DeleteModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5>Delete Candidate</h5>
            </div>

            <div class="modal-body"></div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                <button id="btnYes" class="btn btn-danger">Yes</button>
                <h1>shata</h1>
            </div>

        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3"></div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/JavaScript/candidate.js"></script>
