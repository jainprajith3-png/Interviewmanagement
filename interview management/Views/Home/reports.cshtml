@{
    ViewBag.Title = "HR Reports";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    .page-title {
        font-size: 34px;
        font-weight: bold;
        color: #0f172a;
    }

    .report-card {
        border-radius: 15px;
        color: white;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.10);
        transition: 0.3s;
    }

        .report-card:hover {
            transform: translateY(-5px);
        }

        .report-card i {
            font-size: 40px;
            float: right;
            opacity: 0.8;
        }

        .report-card h2 {
            font-weight: bold;
            margin: 0;
        }

        .report-card p {
            margin: 0;
            font-size: 16px;
        }

    .blue {
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
    }

    .green {
        background: linear-gradient(135deg,#16a34a,#15803d);
    }

    .red {
        background: linear-gradient(135deg,#dc2626,#b91c1c);
    }

    .orange {
        background: linear-gradient(135deg,#ea580c,#c2410c);
    }

    .report-container {
        background: white;
        border-radius: 15px;
        padding: 20px;
        margin-top: 25px;
        box-shadow: 0 3px 12px rgba(0,0,0,0.08);
    }

    .table th {
        background: #2563eb;
        color: white;
        text-align: center;
    }

    .table td {
        text-align: center;
        vertical-align: middle;
    }
</style>

<div class="container-fluid">

    <!-- Page Header -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="page-title">
                HR Reports
            </h1>

            <p class="text-muted">
                View hiring reports and interview statistics
            </p>

        </div>

        <div>

            <button class="btn btn-primary me-2">

                <i class="bi bi-eye-fill"></i>
                View Report

            </button>

            <button class="btn btn-success me-2">

                <i class="bi bi-printer-fill"></i>
                Print Report

            </button>

            <button class="btn btn-danger">

                <i class="bi bi-file-earmark-pdf-fill"></i>
                Export PDF

            </button>

        </div>

    </div>

    <!-- Summary Cards -->

    <div class="row g-4">

        <div class="col-md-3">

            <div class="report-card blue">

                <i class="bi bi-people-fill"></i>

                <h2>0</h2>

                <p>Total Candidates</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="report-card green">

                <i class="bi bi-check-circle-fill"></i>

                <h2>0</h2>

                <p>Selected Candidates</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="report-card red">

                <i class="bi bi-x-circle-fill"></i>

                <h2>0</h2>

                <p>Rejected Candidates</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="report-card orange">

                <i class="bi bi-hourglass-split"></i>

                <h2>0</h2>

                <p>Pending Interviews</p>

            </div>

        </div>

    </div>

    <!-- Monthly Hiring Report -->

    <div class="report-container">

        <h4 class="mb-4">

            <i class="bi bi-bar-chart-fill text-primary"></i>
            Monthly Hiring Report

        </h4>

        <div class="table-responsive">

            <table class="table table-bordered table-striped">

                <thead>

                    <tr>

                        <th>Month</th>
                        <th>Total Candidates</th>
                        <th>Selected</th>
                        <th>Rejected</th>
                        <th>Pending</th>

                    </tr>

                </thead>


                       
            </table>

        </div>

    </div>

    <!-- Detailed Report -->

    <div class="report-container">

        <h4 class="mb-4">

            <i class="bi bi-file-earmark-text-fill text-success"></i>
            Candidate Status Report

        </h4>

        <div class="table-responsive">

            <table class="table table-bordered table-hover">

               

                
            </table>

        </div>

    </div>

</div>